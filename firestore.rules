rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuario solo puede leer y escribir su propio documento de configuración.
    // uid de Firestore == uid de Firebase Auth, así nadie accede a la config (API key,
    // fondo, tema, proveedor) de otra cuenta.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Cubre todas las subcolecciones (historial de chat: sessions/{sid} y
    // sessions/{sid}/messages/{mid}). El documento de settings de arriba no las incluye.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
